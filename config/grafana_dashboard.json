{
  "__inputs": [],
  "__requires": [],
  "title": "RE_OS Operations",
  "uid": "re_os_operations",
  "version": 2,
  "timezone": "browser",
  "editable": true,
  "graphTooltip": 0,
  "templating": {
    "list": [
      {
        "name": "source",
        "type": "query",
        "query": "label_values(scraper_runs_total, source)",
        "refresh": 1,
        "includeAll": true,
        "multi": true,
        "sort": 1
      },
      {
        "name": "tier",
        "type": "query",
        "query": "label_values(llm_router_fallbacks_total, tier)",
        "refresh": 1,
        "includeAll": true,
        "multi": true,
        "sort": 1
      },
      {
        "name": "stage",
        "type": "query",
        "query": "label_values(pipeline_stage_duration_seconds_bucket, stage)",
        "refresh": 1,
        "includeAll": true,
        "multi": true,
        "sort": 1
      },
      {
        "name": "query_name",
        "type": "query",
        "query": "label_values(db_query_duration_seconds_bucket, query_name)",
        "refresh": 1,
        "includeAll": true,
        "multi": true,
        "sort": 1
      }
    ]
  },
  "panels": [
    {
      "title": "Scraper Success Rate by Source",
      "type": "stat",
      "id": 1,
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "sum by (source) (rate(scraper_runs_total{status=\"success\"}[24h])) / sum by (source) (rate(scraper_runs_total[24h])) * 100",
          "legendFormat": "{{source}}",
          "interval": "60s"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "color": { "mode": "continuous-GrYlRd" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "orange", "value": 80 },
              { "color": "green", "value": 95 }
            ]
          }
        }
      },
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "horizontal",
        "reduceOptions": {
          "calcs": ["lastNotNull"]
        },
        "textMode": "auto"
      }
    },
    {
      "title": "LLM Router Fallback Rate by Tier",
      "type": "bargauge",
      "id": 2,
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "sum by (tier) (rate(llm_router_fallbacks_total[24h]))",
          "legendFormat": "{{tier}}",
          "interval": "60s"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "cps",
          "color": { "mode": "palette-classic" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 0.01 },
              { "color": "red", "value": 0.05 }
            ]
          }
        }
      },
      "options": {
        "displayMode": "gradient",
        "orientation": "horizontal",
        "reduceOptions": {
          "calcs": ["lastNotNull"]
        },
        "showUnfilled": true
      }
    },
    {
      "title": "Pipeline Stage Duration p95",
      "type": "timeseries",
      "id": 3,
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le, stage) (rate(pipeline_stage_duration_seconds_bucket[24h])))",
          "legendFormat": "{{stage}}",
          "interval": "120s"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "color": { "mode": "palette-classic" }
        }
      },
      "options": {
        "legend": {
          "calcs": ["mean", "max"],
          "displayMode": "table",
          "placement": "bottom"
        },
        "tooltip": { "mode": "multi" }
      }
    },
    {
      "title": "DB Query Latency p95 for v_market_brief",
      "type": "timeseries",
      "id": 4,
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le, query_name) (rate(db_query_duration_seconds_bucket[24h])))",
          "legendFormat": "p95 {{query_name}}",
          "interval": "120s"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "color": { "mode": "palette-classic" }
        }
      },
      "options": {
        "legend": {
          "calcs": ["mean", "max"],
          "displayMode": "table",
          "placement": "bottom"
        },
        "tooltip": { "mode": "multi" }
      }
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39
}
