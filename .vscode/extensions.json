    "cweijan.vscode-postgresql-client2",
    "mtxr.sqltools",
    "mtxr.sqltools-driver-pg",
    "ckolkman.vscode-postgres",                // inline SQL results in editor

    // ── API testing ───────────────────────────────────────────────────────
    "rangav.vscode-thunder-client",            // test RERA POST endpoint, no Postman needed

