    "anthropic.claude-code",

    // ── Python ────────────────────────────────────────────────────────────
    "ms-python.python",
    "ms-python.pylance",
    "ms-python.black-formatter",
    "ms-python.debugpy",

    // ── Docker ────────────────────────────────────────────────────────────
    "ms-azuretools.vscode-docker",
    "ms-vscode-remote.remote-containers",      // code INSIDE the agents container

