    "mechatroner.rainbow-csv",
    "zainchen.json",
    "nickdemayo.vscode-json-editor",
    "mikestead.dotenv",                        // .env syntax highlighting + key autocomplete

    // ── Git ───────────────────────────────────────────────────────────────
    "eamodio.gitlens",

    // ── Quality of life ───────────────────────────────────────────────────
    "christian-kohler.path-intellisense",
