      "group": "build",
      "presentation": { "reveal": "always", "panel": "shared" },
      "problemMatcher": []
    },

    // ── Scrapers (test standalone) ─────────────────────────────────────────
    {
      "label": "🔍 Test: RERA Scraper",
      "type": "shell",
      "command": "docker compose exec agents python scrapers/rera_karnataka.py --market Yelahanka",
