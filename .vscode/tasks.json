{
  "version": "2.0.0",
  "tasks": [

    // ── Docker ────────────────────────────────────────────────────────────
    {
      "label": "🐳 Docker: Start Stack",
      "type": "shell",
      "command": "docker compose up -d",
      "group": "build",
      "presentation": { "reveal": "always", "panel": "shared" },
      "problemMatcher": []
    },
    {
      "label": "🐳 Docker: Stop Stack",
      "type": "shell",
      "command": "docker compose down",
      "group": "build",
      "presentation": { "reveal": "always", "panel": "shared" },
      "problemMatcher": []
    },
    {
      "label": "🐳 Docker: Restart Agents Container",
      "type": "shell",
      "command": "docker compose restart agents",
      "group": "build",
      "presentation": { "reveal": "always", "panel": "shared" },
      "problemMatcher": []
    },
    {
      "label": "🐳 Docker: Show Container Status",
      "type": "shell",
      "command": "docker compose ps",
      "group": "build",
      "presentation": { "reveal": "always", "panel": "shared" },
      "problemMatcher": []
    },

    // ── Run Crew ──────────────────────────────────────────────────────────
    {
      "label": "🚀 Run: All Markets",
      "type": "shell",
      "command": "docker compose exec agents python crews/market_intel_crew.py",
      "group": { "kind": "build", "isDefault": true },
      "presentation": { "reveal": "always", "panel": "dedicated", "clear": true },
      "problemMatcher": []
    },
    {
      "label": "🚀 Run: Yelahanka",
      "type": "shell",
      "command": "docker compose exec agents python crews/market_intel_crew.py --market Yelahanka",
      "group": "build",
      "presentation": { "reveal": "always", "panel": "dedicated", "clear": true },
      "problemMatcher": []
    },
    {
      "label": "🚀 Run: Devanahalli",
      "type": "shell",
      "command": "docker compose exec agents python crews/market_intel_crew.py --market Devanahalli",
      "group": "build",
      "presentation": { "reveal": "always", "panel": "dedicated", "clear": true },
      "problemMatcher": []
    },
    {
      "label": "🚀 Run: Hebbal",
      "type": "shell",
      "command": "docker compose exec agents python crews/market_intel_crew.py --market Hebbal",
      "group": "build",
      "presentation": { "reveal": "always", "panel": "dedicated", "clear": true },
      "problemMatcher": []
    },

    // ── Status & Logs ─────────────────────────────────────────────────────
    {
      "label": "📊 System Status Dashboard",
      "type": "shell",
      "command": "python utils/status.py",
      "group": "test",
      "presentation": { "reveal": "always", "panel": "shared", "clear": true },
      "problemMatcher": []
    },
    {
      "label": "📋 Show Run History",
      "type": "shell",
      "command": "docker compose exec agents python config/run_logger.py",
      "group": "test",
      "presentation": { "reveal": "always", "panel": "shared" },
      "problemMatcher": []
    },
    {
      "label": "📋 Tail Live Log",
      "type": "shell",
      "command": "Get-Content logs/crew.log -Wait -Tail 50",
      "group": "test",
      "presentation": { "reveal": "always", "panel": "dedicated" },
      "problemMatcher": []
    },

    // ── Ollama ────────────────────────────────────────────────────────────
    {
      "label": "🦙 Ollama: Pull llama3.1:8b",
      "type": "shell",
      "command": "docker compose exec ollama ollama pull llama3.1:8b",
