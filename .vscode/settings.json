{
  // ── Python ────────────────────────────────────────────────────────────────
  "python.defaultInterpreterPath": "C:\\Users\\Jinu Joshi\\AppData\\Local\\Programs\\Python\\Python313\\python.exe",
  "python.analysis.typeCheckingMode": "basic",
  "python.analysis.autoImportCompletions": true,
  "[python]": {
    "editor.formatOnSave": true,
    "editor.defaultFormatter": "ms-python.black-formatter",
    "editor.tabSize": 4
  },

  // ── Editor ────────────────────────────────────────────────────────────────
  "editor.rulers": [100],
  "editor.wordWrap": "off",
  "editor.minimap.enabled": false,
  "editor.bracketPairColorization.enabled": true,
  "editor.suggestSelection": "first",
  "editor.stickyScroll.enabled": true,

  // ── Files ─────────────────────────────────────────────────────────────────
  "files.exclude": {
    "**/__pycache__": true,
    "**/*.pyc": true,
    "**/.pytest_cache": true,
    "**/node_modules": true
  },
  "files.associations": {
    "*.env": "dotenv",
    "docker-compose*.yml": "dockercompose",
    "*.jsonl": "jsonl"
  },
  "files.autoSave": "afterDelay",
  "files.autoSaveDelay": 1000,

  // ── Terminal ──────────────────────────────────────────────────────────────
  "terminal.integrated.defaultProfile.windows": "PowerShell",
  "terminal.integrated.fontSize": 13,
  "terminal.integrated.scrollback": 10000,
  "terminal.integrated.persistentSessionReviveProcess": "onExitAndWindowClose",

  // ── Docker extension ──────────────────────────────────────────────────────
  "docker.composeCommand": "docker compose",

  // ── Search exclusions ─────────────────────────────────────────────────────
  "search.exclude": {
    "**/logs/*.jsonl": true,
    "**/outputs/**": true,
    "**/__pycache__": true
  },

  // ── Explorer ──────────────────────────────────────────────────────────────
  "explorer.fileNesting.enabled": true,
  "explorer.fileNesting.patterns": {
    "docker-compose.yml": "docker-compose.override.yml,docker-compose.*.yml",
    ".env": ".env.*",
    "run.bat": "run.ps1",
    "CLAUDE.md": "MODELS.md,SETUP.md,BEGINNER_GUIDE.md"
  },

  // ── SQLTools — pre-configured RE_OS DB connection ─────────────────────────
  // Connect via: Ctrl+Shift+P → "SQLTools: Select Connection" → RE_OS Postgres
  "sqltools.connections": [
    {
      "name": "RE_OS Postgres (Docker)",
      "driver": "PostgreSQL",
      "server": "localhost",
      "port": 5432,
      "database": "re_os",
      "username": "re_os_user",
      "password": "re_os_2024",
      "previewLimit": 50,
      "askForPassword": false
    }
  ],
  "sqltools.autoOpenSessionFiles": false,
  "sqltools.results.limit": 100,

  // ── Claude Code ───────────────────────────────────────────────────────────
  // When Claude Code opens this folder, it reads CLAUDE.md automatically.
  // The .claude/settings.json pre-authorizes docker compose + python commands.
  "claude.projectContext": "RE_OS: CrewAI multi-agent real estate intelligence for LLS (Bengaluru). Read CLAUDE.md for full context before making any changes.",
  "containers.composeCommand": "docker compose"
}
