# RE_OS Environment Configuration
# Copy this to .env and fill in your values

# RE_OS — Environment Configuration Template
# Copy to .env and fill in your keys. Never commit .env.
#
# LLM Routing (priority order):
#   HEAVY agents  (CEO):               Groq → Gemini Flash → NVIDIA 405B → OpenRouter → Ollama
#   ANALYSIS agents (Analyst):         Cerebras → Groq → Gemini Flash → NVIDIA → Ollama
#   LIGHT agents  (Scraper):           Cerebras → Gemini Gemma 27B → NVIDIA → Ollama

# ── DATABASE ──────────────────────────────────────────────────────────────────
# REQUIRED — set before first `docker compose up`. Cannot be left blank.
DB_PASSWORD=your_secure_db_password_here

# ── TIER 0A: CEREBRAS (ANALYSIS + LIGHT primary — unlimited daily free tier) ───
# 1M tokens/day free. Primary for Scraper + Analyst agents. 8,192-token context cap.
# Sign up: cloud.cerebras.ai — no card required
# Key format: csk-...
CEREBRAS_API_KEY=csk_your-key-here

# Cerebras model override (default: gpt-oss-120b in settings.py)
# CEREBRAS_MODEL=gpt-oss-120b

# ── TIER 1: GROQ (HEAVY primary — CEO Agent) ──────────────────────────────────
# Free tier: 30k TPM Scout, 1,000 req/day. Blazing fast for CEO synthesis.
# Sign up: console.groq.com — no card required, no phone required
# Key format: gsk_...
GROQ_API_KEY=gsk_your-key-here

# Model overrides (defaults already set in settings.py):
# GROQ_CEO_MODEL=llama-3.3-70b-versatile
# GROQ_ANALYST_MODEL=llama-4-scout-instruct

# ── TIER 1B: GEMINI (CEO fallback + Scraper LIGHT fallback) ──────────────────
# Free tier: 250k TPM (Flash), 14.4k req/day (Gemma 27b for light tasks).
# Sign up: aistudio.google.com — no card required
# Key format: AIza...
GEMINI_API_KEY=AIza_your-key-here

# ── TIER 2: NVIDIA NIM (backup — CEO + Analyst) ───────────────────────────────
# Free tier: 40 req/min. Includes llama-3.1-405B (largest free model anywhere).
# Sign up: build.nvidia.com → Catalog → Get API Key (phone verification required)
# Key format: nvapi-...
NVIDIA_API_KEY=nvapi-your-key-here

# Model overrides:
# NVIDIA_CEO_MODEL=meta/llama-3.1-405b-instruct
# NVIDIA_ANALYST_MODEL=nvidia/llama-3.1-nemotron-70b-instruct

# ── TIER 3: OPENROUTER (last resort — all agents) ─────────────────────────────
# Free tier: 50 req/day (1,000/day with $10 lifetime topup — one-time, not monthly)
# Sign up: openrouter.ai — free account, no card required for free models
# Key format: sk-or-v1-...
OPENROUTER_API_KEY=sk-or-v1-your-key-here

# Model override:
# OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct:free

# ── TIER 0: OLLAMA (local Docker — light agents, always available) ────────────
# No key needed — runs in your Docker container
# Primary for Scraper, Parser, Organizer agents (unlimited, zero rate limits)
OLLAMA_MODEL=llama3.1:8b

# ── TARGET MARKETS ────────────────────────────────────────────────────────────
TARGET_MARKETS=Yelahanka,Devanahalli,Hebbal

# ── DASHBOARD AUTH ────────────────────────────────────────────────────────────
# Optional: set to require API key for pipeline trigger endpoints (X-API-Key header)
# Leave blank to disable auth (local-only mode). Set in production to prevent
# unauthorised pipeline runs from any network peer.
DASHBOARD_API_KEY=

# Zero-downtime key rotation: set OLD_KEY here while rotating to new DASHBOARD_API_KEY.
# Both keys will be accepted simultaneously. Remove PREV once clients have migrated.
DASHBOARD_API_KEY_PREV=

# CORS allowlist for dashboard JS clients. Comma-separated origins.
# Accepts: http://localhost:8050 (default), or your nginx/proxy origin.
DASHBOARD_ALLOWED_ORIGINS=http://localhost:8050

# Telegram bot for alerts
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=


# ── Discord Alerts (Phase 7) ──
# Create a Discord server, add channels, right-click each → Edit Channel → Integrations → Webhooks → New Webhook → Copy URL
# Channel structure: #rera-yelahanka, #rera-devanahalli, #rera-hebbal, #competitor-launches, #price-signals, #intel-reports, #re-os-health
DISCORD_WEBHOOK_RERA_YELAHANKA=
DISCORD_WEBHOOK_RERA_DEVANAHALLI=
DISCORD_WEBHOOK_RERA_HEBBAL=
DISCORD_WEBHOOK_COMPETITOR=
DISCORD_WEBHOOK_PRICE=
DISCORD_WEBHOOK_INTEL=
DISCORD_WEBHOOK_SYSTEM=
# General-purpose fallback webhook — used when channel-specific URL is unset.
# REQUIRED in production: at least one of the above OR this must be set.
DISCORD_WEBHOOK_URL=

# ── TIER 4: SAMBANOVA (free, ongoing — 20M tok/day, 20 RPM) ──────────────────
# Models: Llama-3.3-70B, DeepSeek-R1 671B, DeepSeek-V3, Qwen-2.5-72B
# Sign up: cloud.sambanova.ai — no credit card required
# Used as CEO + Analysis fallback (after NVIDIA, before OpenRouter)
SAMBANOVA_API_KEY=
SAMBANOVA_BASE_URL=https://api.sambanova.ai/v1
# Note: SAMBANOVA_BASE_URL is hardcoded in config/settings.py — only override if SambaNova changes their API endpoint

# ── TIER 5: CLOUDFLARE WORKERS AI (free, last-resort — 10K neurons/day) ──────
# Last-resort fallback. 10K neurons ≈ 20-100 real requests/day on Llama 8B.
# Fires only when ALL other providers are excluded/rate-limited.
# Sign up: cloudflare.com → Workers & Pages → copy Account ID
# Create API token: My Profile → API Tokens → Create Token → Workers AI template
CLOUDFLARE_API_KEY=
CLOUDFLARE_ACCOUNT_ID=

# ── JINA AI — Web reader + embeddings (free) ──────────────────────────────────
# Reader: prepend r.jina.ai/ to any URL → clean markdown (JS rendered, free)
# Embeddings: 1M token one-time free bucket (jina-embeddings-v3, multilingual 8K ctx)
# Sign up: jina.ai — no credit card required
# With API key: 100 RPM reader, 1M embedding tokens
JINA_API_KEY=

# ── HUGGING FACE — Inference API (FinBERT sentiment, always free+warm) ────────
# Used for: FinBERT news sentiment (nightly batch, no local model needed)
# BERT-class classification models are always warm on free tier — zero cold start.
# Sign up: huggingface.co → Settings → Access Tokens → New token (read scope)
HF_API_KEY=hf_your-token-here

# ── CHROMADB — Semantic intel search ───────────────────────────────────────────
# ChromaDB persistent storage path (inside Docker — maps to chroma_data volume)
CHROMA_DB_PATH=/app/data/chroma

# ── REDIS AUTH ──────────────────────────────────────────────────────────
# Strong password for Redis. Leave empty for no auth (local dev only).
REDIS_PASSWORD=change_me_strong_redis_password

# ── GRAFANA ──────────────────────────────────────────────────────────────
# Admin password for Grafana dashboard (docker-compose.observability.yml).
GRAFANA_PASSWORD=change_me

# ── SCRAPING INTERVALS (hours) ────────────────────────────────────────────────
RERA_SCRAPE_INTERVAL=24
LISTINGS_SCRAPE_INTERVAL=6

# ── LOGGING ────────────────────────────────────────────────────────────────────
# Dashboard log level: DEBUG, INFO (default), WARNING, ERROR
# LOG_LEVEL=INFO
