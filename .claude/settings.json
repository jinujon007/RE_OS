{
  "permissions": {
    "allow": [
      "Bash(docker compose up*)",
      "Bash(docker compose down*)",
      "Bash(docker compose ps*)",
      "Bash(docker compose exec*)",
      "Bash(docker compose restart*)",
      "Bash(docker compose logs*)",
      "Bash(docker compose build*)",
      "Bash(docker exec re_os_db psql*)",
      "Bash(python*)",
      "Bash(pip install*)",
      "Bash(node*)",
      "Bash(cat logs/*)",
      "Bash(tail -* logs/*)",
      "Bash(Get-Content*)",
      "Bash(Get-ChildItem*)",
      "Bash(mkdir*)",
      "Bash(ls *)",
      "Bash(find . *)",
      "Bash(wc *)",
      "Bash(git status*)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(git add*)",
      "Bash(git commit*)",
      "Bash(git push*)",
      "Bash(git remote*)"
    ],
    "deny": [
      "Bash(rm -rf /)",
      "Bash(DROP DATABASE*)",
      "Bash(docker system prune*)"
    ]
  },
  "mcpServers": {
    "postgres": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-postgres",
        "postgresql://re_os_user:re_os_2024@localhost:5432/re_os"
      ]
    }
  }
}
